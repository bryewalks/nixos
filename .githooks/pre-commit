#!/usr/bin/env bash
# Fast repo checks before every commit; bypass with `git commit --no-verify`.
# Full host evals are left to `nix flake check` (slow, run manually).
#
# Note: flake eval only sees tracked files — `git add` new files first.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

echo "pre-commit: treefmt + flake.nix sync checks"
nix build --no-link \
  .#checks.x86_64-linux.treefmt \
  .#checks.x86_64-linux.check-flake-file
