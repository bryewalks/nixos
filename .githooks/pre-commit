#!/usr/bin/env bash
# Fast repo checks before every commit; bypass with `git commit --no-verify`.
# Full host evals are left to `nix flake check` (slow, run manually).
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

# Colors only when stdout is a terminal.
if [ -t 1 ]; then
  green=$'\033[32m' red=$'\033[31m' reset=$'\033[0m'
else
  green='' red='' reset=''
fi

run_check() {
  local label=$1 attr=$2 hint=$3 out
  printf 'pre-commit ▸ %s ' "$label"
  if out=$(nix build --no-link ".#checks.x86_64-linux.$attr" 2>&1); then
    printf '%sok%s\n' "$green" "$reset"
  else
    printf '%sFAIL%s\n%s\nfix with: %s\n' "$red" "$reset" "$out" "$hint"
    exit 1
  fi
}

run_check 'formatting .........' treefmt 'nix fmt'
run_check 'flake.nix sync .....' check-flake-file 'nix run .#write-flake'
